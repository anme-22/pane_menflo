# Copia este archivo a `.env` y ajusta los valores. NUNCA subas `.env` a git.

# ---- PostgreSQL (usado por docker-compose) ----
POSTGRES_USER=pane
POSTGRES_PASSWORD=cambia_esta_contrasena
POSTGRES_DB=panaderia
# Puerto en el host (dentro del contenedor siempre es 5432)
POSTGRES_PORT=5432

# ---- Conexión de Prisma / API ----
# Debe coincidir con las credenciales de arriba. Host = localhost cuando la API
# corre fuera de Docker; usa el nombre del servicio (db) cuando corra en Docker.
DATABASE_URL="postgresql://pane:cambia_esta_contrasena@localhost:5432/panaderia?schema=public"

# ---- Próximas features (todavía NO se usan; descomentar cuando toque) ----
# Puerto HTTP de la API Nest
# API_PORT=3000
# Secreto para firmar los JWT (Feature 2 - Auth)
# JWT_SECRET=
# JWT_EXPIRES_IN=3600s
