// Esquema de Prisma — Sistema de Panadería
// Dominio y nombres de tablas/columnas en español (snake_case en la BD).
// La app vive en el esquema `public`; el censo nacional (solo lectura) vive en
// el esquema `grl` (multiSchema). Cada modelo/enum declara su esquema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // multiSchema: la app en `public`, el censo nacional en `grl`.
  schemas  = ["public", "grl"]
}

/// Tipo (categoría) de una unidad de medida. Cada tipo tiene una unidad base:
/// peso -> gramo, volumen -> mililitro, conteo -> unidad.
enum TipoUnidad {
  peso
  volumen
  conteo

  @@schema("public")
}

/// Roles del sistema (ver CLAUDE.md §7).
/// - super_admin: crea/gestiona usuarios; acceso total.
/// - admin: gestiona el negocio (no necesariamente usuarios).
/// - vendedor: vende, ve inventario/productos en consulta, gestiona clientes.
enum RolUsuario {
  super_admin
  admin
  vendedor

  @@schema("public")
}

/// Usuarios del sistema. Nunca se borran: se desactivan (`activo = false`)
/// para conservar el rastro (coherente con "no borrar registros de negocio").
/// La contraseña SIEMPRE se guarda hasheada (bcrypt), nunca en texto plano.
model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(100)
  email         String     @unique @db.VarChar(150)
  passwordHash  String     @map("password_hash")
  rol           RolUsuario
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  @@map("usuario")
  @@schema("public")
}

/// Catálogo de unidades de medida.
/// `factorABase` = cuánto vale 1 de esta unidad en la unidad base de su tipo.
/// Convertir entre dos unidades del mismo tipo:
///   cantidad * factor_origen / factor_destino
/// Agregar una unidad nueva = insertar una fila (sin tocar código).
model UnidadMedida {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(50)
  abreviatura String     @db.VarChar(10)
  tipo        TipoUnidad
  factorABase Decimal    @map("factor_a_base") @db.Decimal(18, 6)

  comprasComoUnidad Compra[]

  @@map("unidad_medida")
  @@schema("public")
}

/// Producto del catálogo. NO se borra: se desactiva (`activo = false`).
/// El precio NO vive aquí; está en `precio_producto` con historial de vigencia.
model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(150)
  descripcion   String?  @db.VarChar(500)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  precios PrecioProducto[]

  @@map("producto")
  @@schema("public")
}

/// Historial de precios de un producto. El precio ACTUAL es el de
/// `vigenteHasta = NULL`. Al cambiar el precio NO se edita en sitio: se cierra
/// el vigente (`vigenteHasta = ahora`) y se crea uno nuevo. La migración añade
/// un índice ÚNICO PARCIAL que garantiza un solo precio vigente por producto y
/// un CHECK de precio > 0.
model PrecioProducto {
  id           Int       @id @default(autoincrement())
  productoId   Int       @map("producto_id")
  precio       Decimal   @db.Decimal(12, 2)
  vigenteDesde DateTime  @default(now()) @map("vigente_desde")
  vigenteHasta DateTime? @map("vigente_hasta")

  producto Producto @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@map("precio_producto")
  @@schema("public")
}

/// Sucursales del negocio. Esqueleto para esta etapa: se siembra una por
/// defecto y se usará como sucursal automática en features posteriores
/// (inventario, producción, facturas). Sin selector ni administración aún.
model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  esDefault Boolean  @default(false) @map("es_default")
  activa    Boolean  @default(true)
  creadaEn  DateTime @default(now()) @map("creada_en")

  compras     Compra[]
  existencias Existencia[]

  @@map("sucursal")
  @@schema("public")
}

/// Insumo (materia prima). Su `tipo` define la unidad base del stock:
/// peso -> gramo, volumen -> mililitro, conteo -> unidad. El stock SIEMPRE se
/// guarda en unidad base (ver `Existencia`). NO se borra: se desactiva.
model Insumo {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(150)
  tipo          TipoUnidad
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  compras     Compra[]
  existencias Existencia[]

  @@map("insumo")
  @@schema("public")
}

/// Compra (lote) de un insumo. Registra cantidad + unidad de compra + costo
/// TOTAL; al guardar se convierte a unidad base y se calcula el costo por
/// unidad base del lote. Alimenta el costo histórico (promedio ponderado).
/// Lleva `sucursalId` (sucursal por defecto; sin selector aún).
model Compra {
  id                 Int      @id @default(autoincrement())
  insumoId           Int      @map("insumo_id")
  sucursalId         Int      @map("sucursal_id")
  fecha              DateTime @default(now())
  cantidadCompra     Decimal  @map("cantidad_compra") @db.Decimal(18, 4)
  unidadCompraId     Int      @map("unidad_compra_id")
  costo              Decimal  @db.Decimal(12, 2)
  cantidadBase       Decimal  @map("cantidad_base") @db.Decimal(18, 4)
  costoPorUnidadBase Decimal  @map("costo_por_unidad_base") @db.Decimal(18, 6)
  creadoEn           DateTime @default(now()) @map("creado_en")

  insumo       Insumo       @relation(fields: [insumoId], references: [id])
  unidadCompra UnidadMedida @relation(fields: [unidadCompraId], references: [id])
  sucursal     Sucursal     @relation(fields: [sucursalId], references: [id])

  @@index([insumoId])
  @@map("compra")
  @@schema("public")
}

/// Existencia (saldo) de un insumo por sucursal. `cantidadBase` en unidad base
/// y `costoPromedio` = costo promedio ponderado por unidad base. Se actualiza
/// transaccionalmente en cada compra. Único por (insumo, sucursal).
model Existencia {
  id            Int      @id @default(autoincrement())
  insumoId      Int      @map("insumo_id")
  sucursalId    Int      @map("sucursal_id")
  cantidadBase  Decimal  @default(0) @map("cantidad_base") @db.Decimal(18, 4)
  costoPromedio Decimal  @default(0) @map("costo_promedio") @db.Decimal(18, 6)
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  insumo   Insumo   @relation(fields: [insumoId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([insumoId, sucursalId])
  @@map("existencia")
  @@schema("public")
}

/// Cliente de la panadería (Feature 4). La `identidad` (13 chars) es la clave
/// natural. NO se borra: se desactiva (`activo = false`). El `sexo` guarda el
/// código del catálogo (1 = Masculino, 2 = Femenino; otros = no especificado),
/// tolerando códigos como 0/9 sin romper nada.
model Cliente {
  identidad     String   @id @db.Char(13)
  nombre        String   @db.VarChar(101)
  apellido      String   @db.VarChar(101)
  telefono      String?  @db.VarChar(20)
  sexo          Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  @@map("cliente")
  @@schema("public")
}

/// Censo nacional (esquema `grl`). SOLO LECTURA: la app NUNCA escribe aquí; se
/// usa para autocompletar nombres y sexo del cliente a partir de la identidad.
/// Los ~5M registros se cargan UNA vez desde un volcado externo (ver README),
/// no por Prisma; la migración solo crea la tabla, la PK y el índice de nombre.
/// Índice por (apellido, nombre). En la BD se crea con `text_pattern_ops`
/// (migración `clientes_censo`) para soportar búsqueda por prefijo (LIKE
/// 'APELLIDO%'); aquí se declara como btree simple a propósito: Prisma no puede
/// rastrear operator classes vía `raw()` y, si se declararan, re-propondría el
/// índice en cada `migrate dev` (drift que reconstruiría el índice sobre ~5M
/// filas). Prisma trata ambas formas como equivalentes al comparar, así que NO
/// hay drift y el índice real (con prefijo) se conserva intacto.
model CensoNacional {
  identidad       String    @id @db.Char(13)
  primerNombre    String    @map("primer_nombre") @db.VarChar(50)
  segundoNombre   String?   @map("segundo_nombre") @db.VarChar(50)
  primerApellido  String    @map("primer_apellido") @db.VarChar(50)
  segundoApellido String?   @map("segundo_apellido") @db.VarChar(50)
  codSexo         Int       @map("cod_sexo")
  fechaNacimiento DateTime? @map("fecha_nacimiento") @db.Date

  @@index([primerApellido, primerNombre], map: "censo_nacional_nombre_idx")
  @@map("censo_nacional")
  @@schema("grl")
}
