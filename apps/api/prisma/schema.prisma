// Esquema de Prisma — Sistema de Panadería
// Dominio y nombres de tablas/columnas en español (snake_case en la BD).
// La app vive en el esquema `public`; el censo nacional (solo lectura) vive en
// el esquema `grl` (multiSchema). Cada modelo/enum declara su esquema.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  // multiSchema: la app en `public`, el censo nacional en `grl`.
  schemas  = ["public", "grl"]
}

/// Tipo (categoría) de una unidad de medida. Cada tipo tiene una unidad base:
/// peso -> gramo, volumen -> mililitro, conteo -> unidad.
enum TipoUnidad {
  peso
  volumen
  conteo

  @@schema("public")
}

/// Estado de una orden de producción (Feature 7).
/// BORRADOR: se planifica y edita libre. CONFIRMADA: ya descontó insumos del
/// inventario y "congeló" su costo del momento (no vuelve a descontar). ANULADA:
/// se anula con motivo dejando rastro (no se borra). Coherente con "no borrar
/// registros de negocio".
enum EstadoProduccion {
  BORRADOR
  CONFIRMADA
  ANULADA

  @@schema("public")
}

/// Tipo de movimiento de inventario (Feature 7). Hoy se usa SALIDA (consumo de
/// producción). ENTRADA (compras) y AJUSTE quedan reservados para el kardex de
/// la Feature 8; no se generan todavía.
enum TipoMovimiento {
  ENTRADA
  SALIDA
  AJUSTE

  @@schema("public")
}

/// Estado de una factura (Feature 9). BORRADOR: se edita libre. EMITIDA: ya no
/// se reescribe (se anula y se emite otra, o se edita con motivo dejando rastro
/// en la bitácora). ANULADA: terminal, con motivo. Las facturas NO se borran.
enum EstadoFactura {
  BORRADOR
  EMITIDA
  ANULADA

  @@schema("public")
}

/// Tipo de pago de una factura (Feature 9). CONTADO se considera pagada al
/// emitir; CREDITO se salda con abonos (el saldo/estado de pago se calculan).
enum TipoPago {
  CONTADO
  CREDITO

  @@schema("public")
}

/// Roles del sistema (ver CLAUDE.md §7).
/// - super_admin: crea/gestiona usuarios; acceso total.
/// - admin: gestiona el negocio (no necesariamente usuarios).
/// - vendedor: vende, ve inventario/productos en consulta, gestiona clientes.
enum RolUsuario {
  super_admin
  admin
  vendedor

  @@schema("public")
}

/// Usuarios del sistema. Nunca se borran: se desactivan (`activo = false`)
/// para conservar el rastro (coherente con "no borrar registros de negocio").
/// La contraseña SIEMPRE se guarda hasheada (bcrypt), nunca en texto plano.
model Usuario {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(100)
  email         String     @unique @db.VarChar(150)
  passwordHash  String     @map("password_hash")
  rol           RolUsuario
  activo        Boolean    @default(true)
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  facturas         Factura[]
  bitacoras        FacturaBitacora[]
  cajasAbiertas    CajaSesion[]     @relation("CajaApertura")
  cajasCerradas    CajaSesion[]     @relation("CajaCierre")
  movimientosCaja  MovimientoCaja[]

  @@map("usuario")
  @@schema("public")
}

/// Catálogo de unidades de medida.
/// `factorABase` = cuánto vale 1 de esta unidad en la unidad base de su tipo.
/// Convertir entre dos unidades del mismo tipo:
///   cantidad * factor_origen / factor_destino
/// Agregar una unidad nueva = insertar una fila (sin tocar código).
model UnidadMedida {
  id          Int        @id @default(autoincrement())
  nombre      String     @unique @db.VarChar(50)
  abreviatura String     @db.VarChar(10)
  tipo        TipoUnidad
  factorABase Decimal    @map("factor_a_base") @db.Decimal(18, 6)

  comprasComoUnidad      Compra[]
  ingredientesComoUnidad RecetaIngrediente[]

  @@map("unidad_medida")
  @@schema("public")
}

/// Producto del catálogo. NO se borra: se desactiva (`activo = false`).
/// El precio NO vive aquí; está en `precio_producto` con historial de vigencia.
model Producto {
  id            Int      @id @default(autoincrement())
  nombre        String   @db.VarChar(150)
  descripcion   String?  @db.VarChar(500)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  precios         PrecioProducto[]
  receta          Receta?
  ordenes         OrdenProduccion[]
  detallesFactura FacturaDetalle[]

  @@map("producto")
  @@schema("public")
}

/// Historial de precios de un producto. El precio ACTUAL es el de
/// `vigenteHasta = NULL`. Al cambiar el precio NO se edita en sitio: se cierra
/// el vigente (`vigenteHasta = ahora`) y se crea uno nuevo. La migración añade
/// un índice ÚNICO PARCIAL que garantiza un solo precio vigente por producto y
/// un CHECK de precio > 0.
model PrecioProducto {
  id           Int       @id @default(autoincrement())
  productoId   Int       @map("producto_id")
  precio       Decimal   @db.Decimal(12, 2)
  vigenteDesde DateTime  @default(now()) @map("vigente_desde")
  vigenteHasta DateTime? @map("vigente_hasta")

  producto Producto @relation(fields: [productoId], references: [id])

  @@index([productoId])
  @@map("precio_producto")
  @@schema("public")
}

/// Sucursales del negocio. Esqueleto para esta etapa: se siembra una por
/// defecto y se usará como sucursal automática en features posteriores
/// (inventario, producción, facturas). Sin selector ni administración aún.
model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  esDefault Boolean  @default(false) @map("es_default")
  activa    Boolean  @default(true)
  creadaEn  DateTime @default(now()) @map("creada_en")

  compras      Compra[]
  existencias  Existencia[]
  ordenes      OrdenProduccion[]
  movimientos  MovimientoInventario[]
  facturas     Factura[]
  cajaSesiones CajaSesion[]

  @@map("sucursal")
  @@schema("public")
}

/// Insumo (materia prima). Su `tipo` define la unidad base del stock:
/// peso -> gramo, volumen -> mililitro, conteo -> unidad. El stock SIEMPRE se
/// guarda en unidad base (ver `Existencia`). NO se borra: se desactiva.
model Insumo {
  id            Int        @id @default(autoincrement())
  nombre        String     @db.VarChar(150)
  tipo          TipoUnidad
  activo        Boolean    @default(true)
  // Umbral de stock bajo (en unidad base). 0 = sin alerta (Feature 8).
  stockMinimo   Decimal    @default(0) @map("stock_minimo") @db.Decimal(18, 4)
  creadoEn      DateTime   @default(now()) @map("creado_en")
  actualizadoEn DateTime   @updatedAt @map("actualizado_en")

  compras            Compra[]
  existencias        Existencia[]
  recetaIngredientes RecetaIngrediente[]
  movimientos        MovimientoInventario[]

  @@map("insumo")
  @@schema("public")
}

/// Compra (lote) de un insumo. Registra cantidad + unidad de compra + costo
/// TOTAL; al guardar se convierte a unidad base y se calcula el costo por
/// unidad base del lote. Alimenta el costo histórico (promedio ponderado).
/// Lleva `sucursalId` (sucursal por defecto; sin selector aún).
model Compra {
  id                 Int      @id @default(autoincrement())
  insumoId           Int      @map("insumo_id")
  sucursalId         Int      @map("sucursal_id")
  fecha              DateTime @default(now())
  cantidadCompra     Decimal  @map("cantidad_compra") @db.Decimal(18, 4)
  unidadCompraId     Int      @map("unidad_compra_id")
  costo              Decimal  @db.Decimal(12, 2)
  cantidadBase       Decimal  @map("cantidad_base") @db.Decimal(18, 4)
  costoPorUnidadBase Decimal  @map("costo_por_unidad_base") @db.Decimal(18, 6)
  proveedorId        Int?     @map("proveedor_id")
  creadoEn           DateTime @default(now()) @map("creado_en")

  insumo       Insumo                 @relation(fields: [insumoId], references: [id])
  unidadCompra UnidadMedida           @relation(fields: [unidadCompraId], references: [id])
  sucursal     Sucursal               @relation(fields: [sucursalId], references: [id])
  proveedor    Proveedor?             @relation(fields: [proveedorId], references: [id])
  movimientos  MovimientoInventario[]

  @@index([insumoId])
  @@index([proveedorId])
  @@map("compra")
  @@schema("public")
}

/// Proveedor de insumos (Feature: compras). NO se borra: se desactiva. El
/// `nombre` es único para evitar duplicados. Se asocia (opcional) a cada compra.
model Proveedor {
  id            Int      @id @default(autoincrement())
  nombre        String   @unique
  telefono      String?
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  compras Compra[]

  @@map("proveedor")
  @@schema("public")
}

/// Existencia (saldo) de un insumo por sucursal. `cantidadBase` en unidad base
/// y `costoPromedio` = costo promedio ponderado por unidad base. Se actualiza
/// transaccionalmente en cada compra. Único por (insumo, sucursal).
model Existencia {
  id            Int      @id @default(autoincrement())
  insumoId      Int      @map("insumo_id")
  sucursalId    Int      @map("sucursal_id")
  cantidadBase  Decimal  @default(0) @map("cantidad_base") @db.Decimal(18, 4)
  costoPromedio Decimal  @default(0) @map("costo_promedio") @db.Decimal(18, 6)
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  insumo   Insumo   @relation(fields: [insumoId], references: [id])
  sucursal Sucursal @relation(fields: [sucursalId], references: [id])

  @@unique([insumoId, sucursalId])
  @@map("existencia")
  @@schema("public")
}

/// Receta de un producto, POR LOTE (quintal/saco). `rendimiento` = bolsas que
/// rinde un lote (ej. 223 por quintal). `unidadLote` es una etiqueta del lote
/// (texto: "quintal", "saco"...). Un producto tiene como mucho UNA receta y
/// puede no tener ninguna. La migración añade CHECK rendimiento > 0.
model Receta {
  id            Int      @id @default(autoincrement())
  productoId    Int      @unique @map("producto_id")
  rendimiento   Int
  unidadLote    String   @default("quintal") @map("unidad_lote") @db.VarChar(50)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  producto     Producto            @relation(fields: [productoId], references: [id])
  ingredientes RecetaIngrediente[]
  ordenes      OrdenProduccion[]

  @@map("receta")
  @@schema("public")
}

/// Ingrediente de una receta: insumo + cantidad en cualquier unidad (del mismo
/// tipo que el insumo). Al costear/consumir se convierte a la unidad base.
/// Se borra en cascada con la receta. La migración añade CHECK cantidad > 0.
model RecetaIngrediente {
  id       Int     @id @default(autoincrement())
  recetaId Int     @map("receta_id")
  insumoId Int     @map("insumo_id")
  cantidad Decimal @db.Decimal(18, 4)
  unidadId Int     @map("unidad_id")

  receta Receta       @relation(fields: [recetaId], references: [id], onDelete: Cascade)
  insumo Insumo       @relation(fields: [insumoId], references: [id])
  unidad UnidadMedida @relation(fields: [unidadId], references: [id])

  @@index([recetaId])
  @@map("receta_ingrediente")
  @@schema("public")
}

/// Orden de producción (Feature 7). Planifica producir `sacos` lotes de un
/// producto que tiene receta. `bolsasEsperadas` se congela al crear
/// (= sacos × rendimiento de la receta). `bolsasReales` se captura DESPUÉS de
/// producir (para medir mermas; merma = esperadas − reales, calculada). Al
/// CONFIRMAR (en una transacción) se descuentan los insumos del inventario, se
/// registra un MovimientoInventario de salida por insumo y se "congela"
/// `costoDelMomento` (insumos valorados al costo promedio vigente). La
/// confirmación es idempotente: una orden CONFIRMADA no vuelve a descontar.
/// Lleva `sucursalId` (sucursal por defecto; sin selector aún).
model OrdenProduccion {
  id              Int              @id @default(autoincrement())
  fecha           DateTime         @default(now())
  productoId      Int              @map("producto_id")
  recetaId        Int              @map("receta_id")
  sucursalId      Int              @map("sucursal_id")
  sacos           Decimal          @db.Decimal(12, 2)
  bolsasEsperadas Int              @map("bolsas_esperadas")
  bolsasReales    Int?             @map("bolsas_reales")
  costoDelMomento Decimal          @default(0) @map("costo_del_momento") @db.Decimal(12, 2)
  estado          EstadoProduccion @default(BORRADOR)
  motivoAnulacion String?          @map("motivo_anulacion") @db.VarChar(300)
  confirmadaEn    DateTime?        @map("confirmada_en")
  creadoEn        DateTime         @default(now()) @map("creado_en")
  actualizadoEn   DateTime         @updatedAt @map("actualizado_en")

  producto    Producto               @relation(fields: [productoId], references: [id])
  receta      Receta                 @relation(fields: [recetaId], references: [id])
  sucursal    Sucursal               @relation(fields: [sucursalId], references: [id])
  movimientos MovimientoInventario[]

  @@index([productoId])
  @@index([estado])
  @@map("orden_produccion")
  @@schema("public")
}

/// Movimiento de inventario (Feature 7+8). Asiento inmutable del kardex: NUNCA se
/// borra. ENTRADA proviene de una compra (origen = `compraId`); SALIDA proviene
/// de confirmar producción (origen = `ordenProduccionId`). `cantidadBase` es la
/// magnitud (positiva) en unidad base y `costoUnitario` el costo por unidad base
/// del movimiento (costo del lote en entradas; promedio vigente en salidas).
/// AJUSTE queda reservado. El tipo indica el signo al reconstruir el saldo.
model MovimientoInventario {
  id                Int            @id @default(autoincrement())
  insumoId          Int            @map("insumo_id")
  sucursalId        Int            @map("sucursal_id")
  tipo              TipoMovimiento
  cantidadBase      Decimal        @map("cantidad_base") @db.Decimal(18, 4)
  costoUnitario     Decimal        @map("costo_unitario") @db.Decimal(18, 6)
  ordenProduccionId Int?           @map("orden_produccion_id")
  compraId          Int?           @map("compra_id")
  /// Motivo del movimiento (usado por los AJUSTE manuales; deja rastro).
  motivo            String?
  /// Dirección de un AJUSTE: true = suma al stock, false = resta. NULL en
  /// ENTRADA/SALIDA y en los AJUSTE de reversión (que siempre suman).
  incrementa        Boolean?
  fecha             DateTime       @default(now())
  creadoEn          DateTime       @default(now()) @map("creado_en")

  insumo          Insumo           @relation(fields: [insumoId], references: [id])
  sucursal        Sucursal         @relation(fields: [sucursalId], references: [id])
  ordenProduccion OrdenProduccion? @relation(fields: [ordenProduccionId], references: [id])
  compra          Compra?          @relation(fields: [compraId], references: [id])

  @@index([insumoId, sucursalId])
  @@index([ordenProduccionId])
  @@index([compraId])
  @@map("movimiento_inventario")
  @@schema("public")
}

/// Cliente de la panadería (Feature 4). La `identidad` (13 chars) es la clave
/// natural. NO se borra: se desactiva (`activo = false`). El `sexo` guarda el
/// código del catálogo (1 = Masculino, 2 = Femenino; otros = no especificado),
/// tolerando códigos como 0/9 sin romper nada.
model Cliente {
  identidad     String   @id @db.Char(13)
  nombre        String   @db.VarChar(101)
  apellido      String   @db.VarChar(101)
  telefono      String?  @db.VarChar(20)
  sexo          Int      @default(0)
  activo        Boolean  @default(true)
  creadoEn      DateTime @default(now()) @map("creado_en")
  actualizadoEn DateTime @updatedAt @map("actualizado_en")

  facturas Factura[]

  @@map("cliente")
  @@schema("public")
}

/// Censo nacional (esquema `grl`). SOLO LECTURA: la app NUNCA escribe aquí; se
/// usa para autocompletar nombres y sexo del cliente a partir de la identidad.
/// Los ~5M registros se cargan UNA vez desde un volcado externo (ver README),
/// no por Prisma; la migración solo crea la tabla, la PK y el índice de nombre.
/// Índice por (apellido, nombre). En la BD se crea con `text_pattern_ops`
/// (migración `clientes_censo`) para soportar búsqueda por prefijo (LIKE
/// 'APELLIDO%'); aquí se declara como btree simple a propósito: Prisma no puede
/// rastrear operator classes vía `raw()` y, si se declararan, re-propondría el
/// índice en cada `migrate dev` (drift que reconstruiría el índice sobre ~5M
/// filas). Prisma trata ambas formas como equivalentes al comparar, así que NO
/// hay drift y el índice real (con prefijo) se conserva intacto.
model CensoNacional {
  identidad       String    @id @db.Char(13)
  primerNombre    String    @map("primer_nombre") @db.VarChar(50)
  segundoNombre   String?   @map("segundo_nombre") @db.VarChar(50)
  primerApellido  String    @map("primer_apellido") @db.VarChar(50)
  segundoApellido String?   @map("segundo_apellido") @db.VarChar(50)
  codSexo         Int       @map("cod_sexo")
  fechaNacimiento DateTime? @map("fecha_nacimiento") @db.Date

  @@index([primerApellido, primerNombre], map: "censo_nacional_nombre_idx")
  @@map("censo_nacional")
  @@schema("grl")
}

/// Configuración del sistema (Feature 9; pantalla de edición en F12). Fila única
/// sembrada. Banderas: ISV (apagado hoy), facturación fiscal/CAI (apagada) y PIN
/// de edición (apagado). Hoy solo se LEE para resolver impuesto y campos fiscales.
model Configuracion {
  id                      Int       @id @default(autoincrement())
  isvActivo               Boolean   @default(false) @map("isv_activo")
  tasaIsv                 Decimal   @default(0) @map("tasa_isv") @db.Decimal(5, 4)
  facturacionFiscalActiva Boolean   @default(false) @map("facturacion_fiscal_activa")
  cai                     String?   @db.VarChar(50)
  caiRango                String?   @map("cai_rango") @db.VarChar(100)
  caiFechaLimite          DateTime? @map("cai_fecha_limite") @db.Date
  pinEdicionActivo        Boolean   @default(false) @map("pin_edicion_activo")
  // Quintales producidos al mes: base para prorratear los costos indirectos
  // POR_MES por lote (mejora de costos indirectos).
  quintalesPorMes         Int       @default(100) @map("quintales_por_mes")
  actualizadoEn           DateTime  @updatedAt @map("actualizado_en")

  @@map("configuracion")
  @@schema("public")
}

/// Periodicidad de un costo indirecto (mejora de costos indirectos).
/// POR_QUINTAL: se aplica por cada lote/quintal producido. POR_MES: es un gasto
/// mensual que se prorratea por lote dividiéndolo entre `quintalesPorMes`.
enum TipoCostoIndirecto {
  POR_QUINTAL
  POR_MES

  @@schema("public")
}

/// Costo indirecto de producción (mano de obra, luz/agua/gas...). Se suma al
/// costo de la receta por lote: los POR_QUINTAL tal cual y los POR_MES
/// prorrateados (monto / quintalesPorMes). NO se borra: se desactiva.
model CostoIndirecto {
  id            Int                @id @default(autoincrement())
  nombre        String             @unique @db.VarChar(150)
  monto         Decimal            @db.Decimal(12, 2)
  tipo          TipoCostoIndirecto
  activo        Boolean            @default(true)
  creadoEn      DateTime           @default(now()) @map("creado_en")
  actualizadoEn DateTime           @updatedAt @map("actualizado_en")

  @@map("costo_indirecto")
  @@schema("public")
}

/// Factura (Feature 9). La verdad histórica de una venta. El detalle copia
/// (snapshot) nombre y precio del producto, así que cambiar `precio_producto`
/// luego NO la altera. `subtotal/impuesto/total` se calculan (estrategia de
/// impuesto por línea) y se guardan al emitir. El estado de pago y el saldo NO
/// son columnas: se calculan desde los abonos. Campos fiscales (cai/numero)
/// nullable, apagados por bandera. Estados BORRADOR→EMITIDA→ANULADA; NO se borra.
model Factura {
  id               Int           @id @default(autoincrement())
  numero           String?       @db.VarChar(50)
  sucursalId       Int           @map("sucursal_id")
  clienteIdentidad String?       @map("cliente_identidad") @db.Char(13)
  usuarioId        Int           @map("usuario_id")
  estado           EstadoFactura @default(BORRADOR)
  tipoPago         TipoPago      @default(CONTADO) @map("tipo_pago")
  // Cómo se pagó una venta de CONTADO (Efectivo/Tarjeta/...). NULL en crédito
  // (ahí el método va por abono). Alimenta el arqueo de caja.
  metodoPago       String?       @map("metodo_pago") @db.VarChar(30)
  fecha            DateTime      @default(now())
  subtotal         Decimal       @default(0) @db.Decimal(12, 2)
  impuesto         Decimal       @default(0) @db.Decimal(12, 2)
  total            Decimal       @default(0) @db.Decimal(12, 2)
  cai              String?       @db.VarChar(50)
  caiRango         String?       @map("cai_rango") @db.VarChar(100)
  caiFechaLimite   DateTime?     @map("cai_fecha_limite") @db.Date
  motivoAnulacion  String?       @map("motivo_anulacion") @db.VarChar(300)
  emitidaEn        DateTime?     @map("emitida_en")
  creadoEn         DateTime      @default(now()) @map("creado_en")
  actualizadoEn    DateTime      @updatedAt @map("actualizado_en")

  sucursal Sucursal          @relation(fields: [sucursalId], references: [id])
  cliente  Cliente?          @relation(fields: [clienteIdentidad], references: [identidad])
  usuario  Usuario           @relation(fields: [usuarioId], references: [id])
  detalles FacturaDetalle[]
  abonos   Abono[]
  bitacora FacturaBitacora[]

  @@index([clienteIdentidad])
  @@index([estado])
  @@map("factura")
  @@schema("public")
}

/// Línea de factura (Feature 9). COPIA `nombreProducto` y `precioUnitario` al
/// momento de la venta (snapshot): la factura no depende de la tabla de precios.
/// `tasaImpuesto` es por línea, default 0 (soporta el caso mixto futuro).
model FacturaDetalle {
  id             Int     @id @default(autoincrement())
  facturaId      Int     @map("factura_id")
  productoId     Int     @map("producto_id")
  nombreProducto String  @map("nombre_producto") @db.VarChar(150)
  precioUnitario Decimal @map("precio_unitario") @db.Decimal(12, 2)
  cantidad       Decimal @db.Decimal(12, 2)
  tasaImpuesto   Decimal @default(0) @map("tasa_impuesto") @db.Decimal(5, 4)

  factura  Factura  @relation(fields: [facturaId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id])

  @@index([facturaId])
  @@map("factura_detalle")
  @@schema("public")
}

/// Abono (pago parcial) de una factura de crédito (Feature 9). El estado de pago
/// (PENDIENTE/PARCIAL/PAGADA) y el saldo se calculan sumando los abonos.
model Abono {
  id        Int      @id @default(autoincrement())
  facturaId Int      @map("factura_id")
  monto     Decimal  @db.Decimal(12, 2)
  fecha     DateTime @default(now())
  metodo    String   @db.VarChar(30)
  creadoEn  DateTime @default(now()) @map("creado_en")

  factura Factura @relation(fields: [facturaId], references: [id])

  @@index([facturaId])
  @@map("abono")
  @@schema("public")
}

/// Bitácora de una factura (Feature 9). Rastro inmutable de quién hizo qué y por
/// qué: se escribe al emitir, al editar una EMITIDA (con motivo obligatorio, una
/// fila por campo cambiado) y al anular. No se borra.
model FacturaBitacora {
  id            Int      @id @default(autoincrement())
  facturaId     Int      @map("factura_id")
  usuarioId     Int      @map("usuario_id")
  cuando        DateTime @default(now())
  campo         String   @db.VarChar(50)
  valorAnterior String?  @map("valor_anterior") @db.VarChar(300)
  valorNuevo    String?  @map("valor_nuevo") @db.VarChar(300)
  motivo        String?  @db.VarChar(300)

  factura Factura @relation(fields: [facturaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([facturaId])
  @@map("factura_bitacora")
  @@schema("public")
}

/// Estado de una sesión de caja (arqueo). ABIERTA: acumula movimientos. CERRADA:
/// terminal, con el conteo físico, el esperado y la diferencia congelados.
enum EstadoCaja {
  ABIERTA
  CERRADA

  @@schema("public")
}

/// Tipo de movimiento manual de caja: dinero que entra (INGRESO) o sale (EGRESO)
/// de la gaveta y que NO es una venta (retiros, pago a proveedor en efectivo…).
enum TipoMovimientoCaja {
  INGRESO
  EGRESO

  @@schema("public")
}

/// Sesión de caja (arqueo). Abre con un fondo (montoInicial), acumula el efectivo
/// del periodo y se cierra contando el efectivo físico contra el esperado. El
/// esperado/diferencia se CALCULAN al cerrar y se congelan. Una sola sesión
/// ABIERTA por sucursal a la vez (índice único parcial). No se borra.
model CajaSesion {
  id                Int        @id @default(autoincrement())
  sucursalId        Int        @map("sucursal_id")
  estado            EstadoCaja @default(ABIERTA)
  montoInicial      Decimal    @map("monto_inicial") @db.Decimal(12, 2)
  usuarioAperturaId Int        @map("usuario_apertura_id")
  abiertaEn         DateTime   @default(now()) @map("abierta_en")
  // Congelados al cerrar:
  montoContado      Decimal?   @map("monto_contado") @db.Decimal(12, 2)
  montoEsperado     Decimal?   @map("monto_esperado") @db.Decimal(12, 2)
  diferencia        Decimal?   @db.Decimal(12, 2)
  usuarioCierreId   Int?       @map("usuario_cierre_id")
  cerradaEn         DateTime?  @map("cerrada_en")
  observacion       String?    @db.VarChar(300)
  creadoEn          DateTime   @default(now()) @map("creado_en")

  sucursal        Sucursal         @relation(fields: [sucursalId], references: [id])
  usuarioApertura Usuario          @relation("CajaApertura", fields: [usuarioAperturaId], references: [id])
  usuarioCierre   Usuario?         @relation("CajaCierre", fields: [usuarioCierreId], references: [id])
  movimientos     MovimientoCaja[]

  @@index([sucursalId])
  @@index([estado])
  @@map("caja_sesion")
  @@schema("public")
}

/// Movimiento manual de caja (ingreso/egreso de efectivo que NO es venta). Las
/// ventas y abonos en efectivo NO se duplican aquí: se calculan por ventana de
/// tiempo al cerrar. INMUTABLE: un movimiento erróneo se corrige con su inverso.
model MovimientoCaja {
  id           Int                @id @default(autoincrement())
  cajaSesionId Int                @map("caja_sesion_id")
  tipo         TipoMovimientoCaja
  monto        Decimal            @db.Decimal(12, 2)
  concepto     String             @db.VarChar(200)
  usuarioId    Int                @map("usuario_id")
  fecha        DateTime           @default(now())

  cajaSesion CajaSesion @relation(fields: [cajaSesionId], references: [id])
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([cajaSesionId])
  @@map("movimiento_caja")
  @@schema("public")
}
